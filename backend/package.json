{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:prod": "npm run db:generate:prod && tsc -p tsconfig.json",
    "db:validate:prod": "sh -c 'DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/followup}\" prisma validate --schema prisma/schema.postgres.prisma'",
    "test": "npm run build && node --test --test-concurrency=1 tests/**/*.test.mjs",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:generate:prod": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push:prod": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:seed": "node prisma/seed.mjs",
    "db:seed:prod": "npm run db:generate:prod && node prisma/seed.mjs",
    "db:init": "node scripts/init-db.mjs",
    "db:reset": "node scripts/init-db.mjs --reset"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "cors": "^2.8.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
